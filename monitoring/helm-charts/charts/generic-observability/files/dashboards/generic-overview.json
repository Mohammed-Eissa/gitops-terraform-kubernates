{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Generic observability — CPU · RAM · Disk · Network · HTTP req/s · req/min · method & status breakdown (NGINX Ingress)",
  "graphTooltip": 1,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["generic-observability"],
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "browser",
  "title": "Generic Observability — Overview",
  "uid": "generic-observability-v1",
  "version": 1,
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource",
        "label": "Datasource"
      },
      {
        "allValue": ".*",
        "current": {},
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "hide": 0,
        "includeAll": true,
        "multi": false,
        "name": "cluster",
        "label": "Cluster",
        "query": "label_values(node_uname_info{job=\"node-exporter\"}, cluster)",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": {},
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "instance",
        "label": "Node",
        "query": "label_values(node_uname_info{job=\"node-exporter\", cluster=~\"$cluster\"}, instance)",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": {},
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "namespace",
        "label": "Namespace",
        "query": "label_values(nginx_ingress_controller_requests, namespace)",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": {},
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "ingress",
        "label": "Ingress",
        "query": "label_values(nginx_ingress_controller_requests{namespace=~\"$namespace\"}, ingress)",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "panels": [

    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "title": "🖥  CPU",
      "type": "row"
    },

    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 12, "lineWidth": 2, "showPoints": "never"},
          "max": 100, "min": 0,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 85}
            ]
          }
        }
      },
      "gridPos": {"h": 8, "w": 16, "x": 0, "y": 1},
      "id": 2,
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max", "mean"]}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "(1 - avg by (instance) (rate(node_cpu_seconds_total{job=\"node-exporter\", mode=\"idle\", instance=~\"$instance\", cluster=~\"$cluster\"}[$__rate_interval]))) * 100",
          "legendFormat": "{{instance}}"
        }
      ],
      "title": "CPU Usage %",
      "type": "timeseries"
    },

    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 0, "lineWidth": 2, "showPoints": "never"},
          "unit": "short", "min": 0
        }
      },
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 1},
      "id": 3,
      "options": {
        "tooltip": {"mode": "multi"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "node_load1{job=\"node-exporter\", instance=~\"$instance\", cluster=~\"$cluster\"}",
          "legendFormat": "1m load avg"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "node_load5{job=\"node-exporter\", instance=~\"$instance\", cluster=~\"$cluster\"}",
          "legendFormat": "5m load avg"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "node_load15{job=\"node-exporter\", instance=~\"$instance\", cluster=~\"$cluster\"}",
          "legendFormat": "15m load avg"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "count without(cpu, mode) (node_cpu_seconds_total{job=\"node-exporter\", instance=~\"$instance\", cluster=~\"$cluster\", mode=\"idle\"})",
          "legendFormat": "CPU cores"
        }
      ],
      "title": "CPU Load Average",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
      "id": 10,
      "title": "🧠 Memory (RAM)",
      "type": "row"
    },

    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 12, "lineWidth": 2, "showPoints": "never", "stacking": {"mode": "normal"}},
          "unit": "bytes", "min": 0
        }
      },
      "gridPos": {"h": 8, "w": 18, "x": 0, "y": 10},
      "id": 11,
      "options": {
        "tooltip": {"mode": "multi"},
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"]}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "node_memory_MemTotal_bytes{job=\"node-exporter\", instance=~\"$instance\", cluster=~\"$cluster\"} - node_memory_MemFree_bytes{job=\"node-exporter\", instance=~\"$instance\", cluster=~\"$cluster\"} - node_memory_Buffers_bytes{job=\"node-exporter\", instance=~\"$instance\", cluster=~\"$cluster\"} - node_memory_Cached_bytes{job=\"node-exporter\", instance=~\"$instance\", cluster=~\"$cluster\"}",
          "legendFormat": "Used"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "node_memory_Cached_bytes{job=\"node-exporter\", instance=~\"$instance\", cluster=~\"$cluster\"}",
          "legendFormat": "Cached"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "node_memory_Buffers_bytes{job=\"node-exporter\", instance=~\"$instance\", cluster=~\"$cluster\"}",
          "legendFormat": "Buffers"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "node_memory_MemFree_bytes{job=\"node-exporter\", instance=~\"$instance\", cluster=~\"$cluster\"}",
          "legendFormat": "Free"
        }
      ],
      "title": "Memory Usage",
      "type": "timeseries"
    },

    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "max": 100, "min": 0, "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 75},
              {"color": "red", "value": 90}
            ]
          }
        }
      },
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 10},
      "id": 12,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "(1 - avg(node_memory_MemAvailable_bytes{job=\"node-exporter\", instance=~\"$instance\", cluster=~\"$cluster\"}) / avg(node_memory_MemTotal_bytes{job=\"node-exporter\", instance=~\"$instance\", cluster=~\"$cluster\"})) * 100",
          "legendFormat": "RAM %"
        }
      ],
      "title": "Memory Used %",
      "type": "gauge"
    },

    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18},
      "id": 20,
      "title": "💾 Disk",
      "type": "row"
    },

    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 0, "lineWidth": 2, "showPoints": "never"},
          "unit": "Bps", "min": 0
        },
        "overrides": [
          {
            "matcher": {"id": "byRegexp", "options": "write"},
            "properties": [{"id": "custom.transform", "value": "negative-Y"}]
          }
        ]
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 19},
      "id": 21,
      "options": {
        "tooltip": {"mode": "multi"},
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"]}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "rate(node_disk_read_bytes_total{job=\"node-exporter\", instance=~\"$instance\", cluster=~\"$cluster\", device=~\"(/dev/)?(mmcblk.p.+|nvme.+|rbd.+|sd.+|vd.+|xvd.+|dm-.+|md.+|dasd.+)\"}[$__rate_interval])",
          "legendFormat": "{{device}} read"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "rate(node_disk_written_bytes_total{job=\"node-exporter\", instance=~\"$instance\", cluster=~\"$cluster\", device=~\"(/dev/)?(mmcblk.p.+|nvme.+|rbd.+|sd.+|vd.+|xvd.+|dm-.+|md.+|dasd.+)\"}[$__rate_interval])",
          "legendFormat": "{{device}} write"
        }
      ],
      "title": "Disk I/O — Read / Write",
      "type": "timeseries"
    },

    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0},
              {"color": "red", "value": 0}
            ]
          }
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "Mounted on"}, "properties": [{"id": "custom.width", "value": 260}]},
          {"matcher": {"id": "byName", "options": "Size"},        "properties": [{"id": "custom.width", "value": 100}]},
          {"matcher": {"id": "byName", "options": "Used"},        "properties": [{"id": "custom.width", "value": 100}]},
          {"matcher": {"id": "byName", "options": "Available"},   "properties": [{"id": "custom.width", "value": 100}]},
          {
            "matcher": {"id": "byName", "options": "Used %"},
            "properties": [
              {"id": "unit", "value": "percentunit"},
              {"id": "custom.cellOptions", "value": {"type": "gauge"}},
              {"id": "max", "value": 1},
              {"id": "min", "value": 0},
              {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.75}, {"color": "red", "value": 0.90}]}}
            ]
          }
        ]
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 19},
      "id": 22,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "max by (mountpoint) (node_filesystem_size_bytes{job=\"node-exporter\", instance=~\"$instance\", cluster=~\"$cluster\", fstype!=\"\", mountpoint!=\"\"})",
          "format": "table", "instant": true, "legendFormat": ""
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "max by (mountpoint) (node_filesystem_avail_bytes{job=\"node-exporter\", instance=~\"$instance\", cluster=~\"$cluster\", fstype!=\"\", mountpoint!=\"\"})",
          "format": "table", "instant": true, "legendFormat": ""
        }
      ],
      "transformations": [
        {"id": "groupBy", "options": {"fields": {
          "Value #A": {"aggregations": ["lastNotNull"], "operation": "aggregate"},
          "Value #B": {"aggregations": ["lastNotNull"], "operation": "aggregate"},
          "mountpoint": {"aggregations": [], "operation": "groupby"}
        }}},
        {"id": "merge"},
        {"id": "calculateField", "options": {"alias": "Used", "binary": {"left": "Value #A (lastNotNull)", "operator": "-", "right": "Value #B (lastNotNull)"}, "mode": "binary"}},
        {"id": "calculateField", "options": {"alias": "Used %", "binary": {"left": "Used", "operator": "/", "right": "Value #A (lastNotNull)"}, "mode": "binary"}},
        {"id": "organize", "options": {"renameByName": {"Value #A (lastNotNull)": "Size", "Value #B (lastNotNull)": "Available", "mountpoint": "Mounted on"}}},
        {"id": "sortBy", "options": {"sort": [{"field": "Mounted on"}]}}
      ],
      "title": "Disk Space Usage",
      "type": "table"
    },

    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 27},
      "id": 30,
      "title": "🌐 Network Traffic",
      "type": "row"
    },

    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 8, "lineWidth": 2, "showPoints": "never"},
          "unit": "bps", "min": 0
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 28},
      "id": 31,
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max", "mean"]}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "rate(node_network_receive_bytes_total{job=\"node-exporter\", instance=~\"$instance\", cluster=~\"$cluster\", device!=\"lo\"}[$__rate_interval]) * 8",
          "legendFormat": "{{instance}} — {{device}} in"
        }
      ],
      "title": "Network — Received (bits/s)",
      "type": "timeseries"
    },

    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 8, "lineWidth": 2, "showPoints": "never"},
          "unit": "bps", "min": 0
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 28},
      "id": 32,
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max", "mean"]}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "rate(node_network_transmit_bytes_total{job=\"node-exporter\", instance=~\"$instance\", cluster=~\"$cluster\", device!=\"lo\"}[$__rate_interval]) * 8",
          "legendFormat": "{{instance}} — {{device}} out"
        }
      ],
      "title": "Network — Transmitted (bits/s)",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 36},
      "id": 40,
      "title": "🔁 HTTP Traffic (NGINX Ingress)",
      "type": "row"
    },

    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 8, "lineWidth": 2, "showPoints": "never"},
          "unit": "reqps", "min": 0
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 37},
      "id": 41,
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max", "mean"]}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum by (ingress, method) (rate(nginx_ingress_controller_requests{namespace=~\"$namespace\", ingress=~\"$ingress\"}[$__rate_interval]))",
          "legendFormat": "{{ingress}} — {{method}}"
        }
      ],
      "title": "Requests / Second — by Ingress & Method",
      "type": "timeseries"
    },

    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 8, "lineWidth": 2, "showPoints": "never"},
          "unit": "short", "min": 0
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 37},
      "id": 42,
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max", "mean"]}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum by (ingress, method) (rate(nginx_ingress_controller_requests{namespace=~\"$namespace\", ingress=~\"$ingress\"}[$__rate_interval])) * 60",
          "legendFormat": "{{ingress}} — {{method}}"
        }
      ],
      "title": "Requests / Minute — by Ingress & Method",
      "type": "timeseries"
    },

    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 8, "lineWidth": 2, "showPoints": "never"},
          "unit": "reqps", "min": 0
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 45},
      "id": 43,
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max", "mean"]}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum by (status) (rate(nginx_ingress_controller_requests{namespace=~\"$namespace\", ingress=~\"$ingress\"}[$__rate_interval]))",
          "legendFormat": "HTTP {{status}}"
        }
      ],
      "title": "Requests / Second — by Status Code",
      "type": "timeseries"
    },

    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "red"},
          "custom": {"fillOpacity": 20, "lineWidth": 2, "showPoints": "never"},
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 5}
            ]
          }
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 45},
      "id": 44,
      "options": {
        "tooltip": {"mode": "multi"},
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"]}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "100 * sum by (ingress) (rate(nginx_ingress_controller_requests{namespace=~\"$namespace\", ingress=~\"$ingress\", status=~\"5..\"}[$__rate_interval])) / sum by (ingress) (rate(nginx_ingress_controller_requests{namespace=~\"$namespace\", ingress=~\"$ingress\"}[$__rate_interval]))",
          "legendFormat": "{{ingress}} — 5xx %"
        }
      ],
      "title": "HTTP 5xx Error Rate %",
      "type": "timeseries"
    },

    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"unit": "reqps"},
        "overrides": [
          {"matcher": {"id": "byName", "options": "Ingress"},  "properties": [{"id": "custom.width", "value": 200}]},
          {"matcher": {"id": "byName", "options": "Method"},   "properties": [{"id": "custom.width", "value": 80}]},
          {"matcher": {"id": "byName", "options": "Status"},   "properties": [{"id": "custom.width", "value": 80}]},
          {"matcher": {"id": "byName", "options": "req/s"},    "properties": [
            {"id": "custom.displayMode", "value": "lcd-gauge"},
            {"id": "min", "value": 0}
          ]}
        ]
      },
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 53},
      "id": 45,
      "options": {"sortBy": [{"displayName": "req/s", "desc": true}]},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sort_desc(sum by (ingress, method, status) (rate(nginx_ingress_controller_requests{namespace=~\"$namespace\", ingress=~\"$ingress\"}[5m])))",
          "format": "table",
          "instant": true,
          "legendFormat": ""
        }
      ],
      "transformations": [
        {"id": "organize", "options": {"renameByName": {"ingress": "Ingress", "method": "Method", "status": "Status", "Value": "req/s"}}}
      ],
      "title": "Top Requests — by Ingress / Method / Status Code",
      "type": "table"
    }

  ]
}
